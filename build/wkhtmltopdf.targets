<Project>
  <!-- Windows-only PDF-export dependency: fetch, cache, verify, and copy next
       to the app binary. Linux builds use the system /usr/bin/wkhtmltopdf. -->
  <PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
    <WkVersion>0.12.6-1</WkVersion>
    <WkArchiveSha256>6ce994c89d5f6018fa158e149a2de8fbbbeb14d8ff5cb656c89893bc556e0557</WkArchiveSha256>
    <WkExeSha256>64d17682320bffd45b2208ed13b136d59139e82573745f14556cf25e95cbd808</WkExeSha256>
    <WkUrl>https://github.com/wkhtmltopdf/packaging/releases/download/$(WkVersion)/wkhtmltox-$(WkVersion).mxe-cross-win64.7z</WkUrl>
    <WkCacheDir>$(LocalAppData)\CalcpadCE\tools\wkhtmltopdf-$(WkVersion)</WkCacheDir>
    <WkArchive>$(WkCacheDir)\wkhtmltox.7z</WkArchive>
    <WkExe>$(WkCacheDir)\wkhtmltopdf.exe</WkExe>

    <!-- Prefer a standard 7-Zip install (its installer doesn't add itself to
         PATH); otherwise bootstrap the standalone 7zr.exe extractor. Not
         hash-pinned: a bad extractor can't produce the SHA256-verified exe. -->
    <_Pf64>$([System.Environment]::GetEnvironmentVariable('ProgramW6432'))</_Pf64>
    <_Pf86>$([System.Environment]::GetEnvironmentVariable('ProgramFiles(x86)'))</_Pf86>
    <Wk7zr>$(WkCacheDir)\7zr.exe</Wk7zr>
    <Wk7zrUrl>https://www.7-zip.org/a/7zr.exe</Wk7zrUrl>
    <SevenZip Condition="Exists('$(_Pf64)\7-Zip\7z.exe')">$(_Pf64)\7-Zip\7z.exe</SevenZip>
    <SevenZip Condition="'$(SevenZip)' == '' and Exists('$(_Pf86)\7-Zip\7z.exe')">$(_Pf86)\7-Zip\7z.exe</SevenZip>
    <SevenZip Condition="'$(SevenZip)' == ''">$(Wk7zr)</SevenZip>
  </PropertyGroup>

  <Target Name="EnsureWkhtmltopdf"
          Condition="'$(OS)' == 'Windows_NT'"
          BeforeTargets="BeforeBuild;BeforePublish"
          Inputs="$(MSBuildThisFileFullPath)"
          Outputs="$(WkExe)">

    <MakeDir Directories="$(WkCacheDir)" />

    <DownloadFile Condition="!Exists('$(WkArchive)')"
                  SourceUrl="$(WkUrl)"
                  DestinationFolder="$(WkCacheDir)"
                  DestinationFileName="wkhtmltox.7z" />

    <GetFileHash Files="$(WkArchive)" Algorithm="SHA256">
      <Output TaskParameter="Items" ItemName="_WkArchiveHashed" />
    </GetFileHash>
    <Error Condition="'%(_WkArchiveHashed.FileHash)' != '$(WkArchiveSha256)'"
           Text="wkhtmltopdf archive SHA256 mismatch. Delete '$(WkArchive)' and rebuild." />

    <DownloadFile Condition="'$(SevenZip)' == '$(Wk7zr)' and !Exists('$(Wk7zr)')"
                  SourceUrl="$(Wk7zrUrl)"
                  DestinationFolder="$(WkCacheDir)"
                  DestinationFileName="7zr.exe" />

    <Exec Command="&quot;$(SevenZip)&quot; e -y &quot;$(WkArchive)&quot; wkhtmltox/bin/wkhtmltopdf.exe -o&quot;$(WkCacheDir)&quot;"
          WorkingDirectory="$(WkCacheDir)"
          IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_SevenZipExit" />
    </Exec>
    <Error Condition="'$(_SevenZipExit)' != '0'"
           Text="Failed to extract wkhtmltopdf with '$(SevenZip)' (exit $(_SevenZipExit)). Delete '$(WkCacheDir)' and rebuild." />

    <GetFileHash Files="$(WkExe)" Algorithm="SHA256">
      <Output TaskParameter="Items" ItemName="_WkExeHashed" />
    </GetFileHash>
    <Error Condition="'%(_WkExeHashed.FileHash)' != '$(WkExeSha256)'"
           Text="wkhtmltopdf.exe SHA256 mismatch." />
  </Target>

  <ItemGroup Condition="'$(OS)' == 'Windows_NT'">
    <Content Include="$(WkExe)">
      <Link>wkhtmltopdf.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>
</Project>
