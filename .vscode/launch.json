{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Wpf: Run",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Wpf: Build",
            "program": "${workspaceFolder}/Calcpad.Wpf/bin/Debug/net10.0-windows/CalcpadCE.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Calcpad.Wpf",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Server: Debug (.NET)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Server: Build (.NET)",
            "program": "${workspaceFolder}/Calcpad.Web/backend/bin/Debug/net10.0/Calcpad.Server.dll",
            "args": ["--urls", "http://127.0.0.1:9420"],
            "cwd": "${workspaceFolder}/Calcpad.Web/backend",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Extension: Run",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            ],
            "outFiles": [
                "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/out/**/*.js"
            ],
            "preLaunchTask": "Extension: Compile & Sync Server"
        },
        {
            // `tauri dev` hot-reloads the Vue frontend and rebuilds the Rust
            // shell on change. Sidecar staging runs via preLaunchTask so the
            // ShellExt lookup in lib.rs resolves.
            "name": "Desktop: Dev (Tauri)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["tauri", "dev"],
            "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-desktop",
            "console": "integratedTerminal",
            "preLaunchTask": "Desktop: Stage Sidecar"
        }
    ]
}
