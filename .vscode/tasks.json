{
    "version": "2.0.0",
    "tasks": [
        // ── Backend (Calcpad.Server) ────────────────────────────────────
        {
            "label": "Server: Start Dev",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/Calcpad.Web/backend/scripts/restart-dev-server.sh"],
            "group": "build",
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Building Calcpad.Server",
                    "endsPattern": "^Server started"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "server"
            }
        },
        {
            "label": "Server: Build Linux",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/Calcpad.Web/backend/scripts/build-linux.sh"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Server: Build Slim Bundle",
            "type": "shell",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "linux": {
                "command": "bash",
                "args": ["${workspaceFolder}/Calcpad.Web/backend/scripts/build-slim-bundle.sh"]
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile", "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}\\Calcpad.Web\\backend\\scripts\\build-slim-bundle.ps1"
                ]
            }
        },
        {
            "label": "Server: Deploy Slim Bundle to Extension",
            "type": "shell",
            "group": "build",
            "dependsOn": "Server: Build Slim Bundle",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "rm -rf ${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/bin && cp -r ${workspaceFolder}/publish/calcpad-server-slim ${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/bin && echo 'Deployed to vscode-calcpad/bin/'"
                ]
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile", "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}\\Calcpad.Web\\backend\\scripts\\deploy-slim-bundle.ps1"
                ]
            }
        },

        // ── Frontend (calcpad-web) ──────────────────────────────────────
        {
            "label": "Web: Dev Server",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-web"
            },
            "group": "build",
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\s*VITE",
                    "endsPattern": "ready in"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "frontend"
            }
        },
        {
            "label": "Web: Build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-web"
            },
            "group": "build",
            "linux": {
                "command": "bash",
                "args": ["-c", "[ -d node_modules ] || npm install && npm run build"]
            },
            "osx": {
                "command": "bash",
                "args": ["-c", "[ -d node_modules ] || npm install && npm run build"]
            },
            "windows": {
                "command": "powershell",
                "args": ["-NoProfile", "-Command", "if(-not(Test-Path node_modules)){npm install}; npm run build"]
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Web: Install Dependencies",
            "type": "shell",
            "command": "npm",
            "args": ["install"],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-web"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },

        // ── Desktop (Neutralino) ────────────────────────────────────────
        {
            "label": "Desktop: Build Server + Assets",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/Calcpad.Web/frontend/calcpad-desktop/build-desktop.sh"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Desktop: Dev Mode",
            "type": "shell",
            "command": "npx",
            "args": ["neu", "run"],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-desktop"
            },
            "group": "build",
            "isBackground": true,
            "dependsOn": "Server: Start Dev",
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^neu:",
                    "endsPattern": "CLI connected"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "desktop"
            }
        },
        {
            "label": "Desktop: Package",
            "type": "shell",
            "command": "npx",
            "args": ["neu", "build"],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-desktop"
            },
            "group": "build",
            "dependsOn": "Desktop: Build Server + Assets",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Desktop: Clean & Rebuild",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "rm -rf dist resources && npx neu build"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-desktop"
            },
            "group": "build",
            "dependsOn": "Desktop: Build Server + Assets",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Desktop: Install via pacman (Arch)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "rm -f *.pkg.tar.zst && makepkg -sif && sudo pacman -U --noconfirm calcpad-ce-*.pkg.tar.zst"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-desktop/packaging/arch"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },

        // ── Server → Extension DLL sync (dev builds) ──────────────────
        {
            "label": "Server: Build & Deploy to Extension",
            "type": "shell",
            "group": "build",
            "dependsOn": [],
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile", "-Command",
                    "dotnet build '${workspaceFolder}\\Calcpad.Web\\backend\\Calcpad.Server.csproj' -c Debug; Copy-Item '${workspaceFolder}\\Calcpad.Web\\backend\\bin\\Debug\\net10.0\\Calcpad.Core.dll','${workspaceFolder}\\Calcpad.Web\\backend\\bin\\Debug\\net10.0\\Calcpad.Server.dll','${workspaceFolder}\\Calcpad.Web\\backend\\bin\\Debug\\net10.0\\Calcpad.Highlighter.dll','${workspaceFolder}\\Calcpad.Web\\backend\\bin\\Debug\\net10.0\\Calcpad.OpenXml.dll' -Destination '${workspaceFolder}\\Calcpad.Web\\frontend\\vscode-calcpad\\bin\\' -Force"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "dotnet build '${workspaceFolder}/Calcpad.Web/backend/Calcpad.Server.csproj' -c Debug && cp -f '${workspaceFolder}/Calcpad.Web/backend/bin/Debug/net10.0/Calcpad.Core.dll' '${workspaceFolder}/Calcpad.Web/backend/bin/Debug/net10.0/Calcpad.Server.dll' '${workspaceFolder}/Calcpad.Web/backend/bin/Debug/net10.0/Calcpad.Highlighter.dll' '${workspaceFolder}/Calcpad.Web/backend/bin/Debug/net10.0/Calcpad.OpenXml.dll' '${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad/bin/'"
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },

        // ── VS Code Extension ───────────────────────────────────────────
        {
            "label": "Extension: Compile",
            "type": "npm",
            "script": "compile",
            "path": "Calcpad.Web/frontend/vscode-calcpad",
            "dependsOn": ["Frontend: Install & Build", "Server: Build & Deploy to Extension"],
            "group": "build",
            "presentation": {
                "panel": "shared",
                "reveal": "silent"
            },
            "problemMatcher": "$tsc"
        },
        {
            "label": "Extension: Watch",
            "type": "npm",
            "script": "watch",
            "path": "Calcpad.Web/frontend/vscode-calcpad",
            "group": "build",
            "isBackground": true,
            "presentation": {
                "panel": "shared",
                "reveal": "silent"
            },
            "problemMatcher": "$tsc-watch"
        },

        // ── Build All ──────────────────────────────────────────────────
        {
            "label": "Frontend: Install & Build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/calcpad-frontend"
            },
            "linux": {
                "command": "bash",
                "args": ["-c", "[ -d node_modules ] || npm install && npm run build"]
            },
            "osx": {
                "command": "bash",
                "args": ["-c", "[ -d node_modules ] || npm install && npm run build"]
            },
            "windows": {
                "command": "powershell",
                "args": ["-NoProfile", "-Command", "if(-not(Test-Path node_modules)){npm install}; npm run build"]
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Extension: Install & Compile",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            },
            "dependsOn": "Frontend: Install & Build",
            "linux": {
                "command": "bash",
                "args": ["-c", "[ -d node_modules ] || npm install && npm run compile"]
            },
            "osx": {
                "command": "bash",
                "args": ["-c", "[ -d node_modules ] || npm install && npm run compile"]
            },
            "windows": {
                "command": "powershell",
                "args": ["-NoProfile", "-Command", "if(-not(Test-Path node_modules)){npm install}; npm run compile"]
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Build All",
            "dependsOn": ["Extension: Install & Compile", "Web: Build"],
            "dependsOrder": "parallel",
            "group": "build",
            "problemMatcher": []
        },

        // ── Compound ────────────────────────────────────────────────────
        {
            "label": "Full Stack: Start Dev",
            "dependsOn": ["Server: Start Dev", "Web: Dev Server"],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Extension + Server: Compile & Start",
            "dependsOn": ["Extension: Compile", "Server: Start Dev"],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "Extension: Compile + Deploy Bundle",
            "dependsOn": ["Extension: Compile", "Server: Deploy Slim Bundle to Extension"],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "Extension: Build VSIX",
            "type": "shell",
            "command": "npx",
            "args": ["vsce", "package", "--no-dependencies"],
            "options": {
                "cwd": "${workspaceFolder}/Calcpad.Web/frontend/vscode-calcpad"
            },
            "dependsOn": "Extension: Compile + Deploy Bundle",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        }
    ]
}