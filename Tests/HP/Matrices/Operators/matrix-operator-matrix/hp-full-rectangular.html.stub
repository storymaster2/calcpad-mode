  <span class="eq">
   <b>
    <var>c1</var>
   </b>
   =
   <var>f</var>
   (
   <b>
    <var>m1</var>
   </b>
   ;
   <b>
    <var>m2</var>
   </b>
   )  =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">0</span>
     <span class="td">1</span>
     <span class="td">1</span>
