 <h1>Logical operators</h1>
 <p>
 </p>
 <p>
  <span class="eq">
   <b>
    <var>c</var>
   </b>
   =
   <var>
    <span class="vec">⃗</span>
    m1
   </var>
   and
   <b>
    <var>m2</var>
   </b>
   =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">1</span>
     <span class="td">
     </span>
    </span>
