<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" 
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  
  <!-- Define version variable -->
  <?define ProductVersion = "1.0.0.0" ?>
  
  <Package Name="CalcpadCE Server" 
           Language="1033" 
           Version="$(var.ProductVersion)" 
           Manufacturer="CalcpadCE Community" 
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-123456789012" 
           InstallScope="perMachine" 
           InstallPrivileges="elevated">
    
    <!-- Simplified upgrade handling for WiX v4/v6 -->
    <MajorUpgrade 
      DowngradeErrorMessage="A newer version of [ProductName] is already installed. Please uninstall the newer version before installing this version."
      Schedule="afterInstallInitialize"
      AllowSameVersionUpgrades="no" />
    
    <!-- Custom property for upgrade detection -->
    <Property Id="UPGRADE_DETECTED" Secure="yes" />
    
    <!-- Custom actions for upgrade handling -->
    <CustomAction Id="SetUpgradeFlag" Property="UPGRADE_DETECTED" Value="1" />
    
    <!-- Install sequence -->
    <InstallExecuteSequence>
      <Custom Action="SetUpgradeFlag" After="FindRelatedProducts" Condition="UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>
    
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="CalcpadCE Server" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="StartupComponents" />
    </Feature>

    <!-- Custom Minimal UI -->
    <UI Id="CustomMinimalUI">
      <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
      <Property Id="WixUI_Mode" Value="Custom" />

      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" Bold="yes" />
      <TextStyle Id="WixUI_Font_Title"  FaceName="Tahoma" Size="9" Bold="yes" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ExitDialog" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="UserExit" />

      <Publish Dialog="WelcomeDlg" Control="Next" Event="EndDialog" Value="Return" Order="2" Condition="1" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" Condition="1" />
    </UI>
    
    <!-- Custom completion message -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" 
              Value="CalcpadCE Server has been successfully installed. The application will start automatically with Windows and run in the system tray. Default server URL: http://localhost:9421" />

    <!-- Installation directory structure -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="CalcpadFolder" Name="CalcpadCE">
        <Directory Id="INSTALLFOLDER" Name="Server" />
      </Directory>
    </StandardDirectory>
    
    <!-- Start Menu directory -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="CalcpadCE Server" />
    </StandardDirectory>

    <!-- Main application components -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Main executable -->
      <Component Id="CalcpadServer.exe" Guid="*" Win64="yes">
        <File Id="CalcpadServer.exe" 
              Source="bin\$(var.Configuration)\net8.0-windows\win-x64\publish\Calcpad.Server.exe" 
              KeyPath="yes" />
        
        <!-- Registry entries for app tracking -->
        <RegistryKey Root="HKLM" Key="SOFTWARE\Calcpad\Server" Action="createAndRemoveOnUninstall">
          <RegistryValue Name="Installed" Value="True" Type="string" />
          <RegistryValue Name="Version" Value="$(var.ProductVersion)" Type="string" />
          <RegistryValue Name="InstallPath" Value="[INSTALLFOLDER]" Type="string" />
          <RegistryValue Name="DefaultPort" Value="9421" Type="string" />
        </RegistryKey>
        
        <!-- Firewall exception registry (Windows will prompt user) -->
        <RegistryKey Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\{$(var.ProductCode)}" Action="createAndRemoveOnUninstall">
          <RegistryValue Name="FirewallException" Value="CalcpadCE Server uses port 9421 for HTTP API access" Type="string" />
        </RegistryKey>
      </Component>
      
      <!-- Runtime dependencies (if any additional files are needed) -->
      <Component Id="RuntimeFiles" Guid="*" Win64="yes">
        <!-- Icon file -->
        <File Id="calcpad.ico" Source="calcpad-server.ico" KeyPath="yes" />
        
        <!-- Sample client HTML file -->
        <File Id="sample_client.html" Source="..\testing\sample-client.html" />
      </Component>
      
      <!-- Configuration directory component -->
      <Component Id="ConfigDirectory" Guid="*" Win64="yes">
        <CreateFolder Directory="INSTALLFOLDER" />
        
        <!-- Environment variable for application data -->
        <Environment Id="CalcpadServerPath" 
                     Name="CALCPAD_SERVER_INSTALL_PATH" 
                     Value="[INSTALLFOLDER]" 
                     System="yes" 
                     Action="set" />
      </Component>
    </ComponentGroup>
    
    <!-- Startup and shortcuts components -->
    <ComponentGroup Id="StartupComponents" Directory="ApplicationProgramsFolder">
      <!-- Start menu shortcut -->
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut Id="CalcpadServerStartMenu"
                  Name="CalcpadCE Server"
                  Description="Start CalcpadCE Server Tray Application"
                  Target="[INSTALLFOLDER]Calcpad.Server.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="CalcpadIcon"
                  IconIndex="0" />
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" 
                       Key="SOFTWARE\Calcpad\Server\Shortcuts" 
                       Name="StartMenu" 
                       Value="1" 
                       Type="integer" 
                       KeyPath="yes" />
      </Component>
      
      <!-- Desktop shortcut (optional, user can choose) -->
      <Component Id="DesktopShortcut" Guid="*">
        <Condition>DESKTOP_SHORTCUT</Condition>
        <Shortcut Id="CalcpadServerDesktop"
                  Name="CalcpadCE Server"
                  Description="Start CalcpadCE Server Tray Application"
                  Target="[INSTALLFOLDER]Calcpad.Server.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="CalcpadIcon"
                  IconIndex="0"
                  Directory="DesktopFolder" />
        <RegistryValue Root="HKCU" 
                       Key="SOFTWARE\Calcpad\Server\Shortcuts" 
                       Name="Desktop" 
                       Value="1" 
                       Type="integer" 
                       KeyPath="yes" />
      </Component>
      
      <!-- Startup registry entry for auto-start -->
      <Component Id="AutoStartup" Guid="*">
        <Condition>AUTO_START</Condition>
        <RegistryValue Root="HKCU"
                       Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                       Name="CalcpadServer"
                       Value="&quot;[INSTALLFOLDER]Calcpad.Server.exe&quot;"
                       Type="string"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
    
    <!-- Property for desktop shortcut -->
    <Property Id="DESKTOP_SHORTCUT" Value="1" />
    
    <!-- Property for auto-start -->
    <Property Id="AUTO_START" Value="1" />
    
    <!-- Icon definition -->
    <Icon Id="CalcpadIcon" SourceFile="calcpad-server.ico" />
    
    <!-- Add/Remove Programs icon -->
    <Property Id="ARPPRODUCTICON" Value="CalcpadIcon" />
    
    <!-- Add/Remove Programs information -->
    <Property Id="ARPHELPLINK" Value="https://github.com/imartincei/CalcpadCE" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/imartincei/CalcpadCE" />
    <Property Id="ARPCOMMENTS" Value="Mathematical calculator and plotter with expression parser and scripting language" />
    
  </Package>
</Wix>