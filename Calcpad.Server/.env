# CalcpadCE Server Configuration
# Copy this file to .env.local to customize your settings

# Server port (default: 9420)
CALCPAD_PORT=9420

# Server host (default: localhost for Windows, 0.0.0.0 for Docker)
CALCPAD_HOST=0.0.0.0

# Environment (Production, Development)
ASPNETCORE_ENVIRONMENT=Production

# Enable HTTPS redirect (true/false)
CALCPAD_ENABLE_HTTPS=false

# CORS settings - comma separated origins, or * for all
CALCPAD_CORS_ORIGINS=*