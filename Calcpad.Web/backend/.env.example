# Calcpad Server Environment Configuration
# Copy this file to .env and configure for your environment

# Main Server Configuration
ASPNETCORE_ENVIRONMENT=Development
CALCPAD_PORT=8080
CALCPAD_HOST=*
ASPNETCORE_URLS=http://+:8080

# Service URLs (Docker internal networking)
PDF_SERVICE_URL=http://pdf-service:3001

# PDF Service Configuration
PDF_SERVICE_PORT=3001
NODE_ENV=development

# Calcpad Isolation
CALCPAD_ISOLATED=true

# Security Settings
DOTNET_EnableDiagnostics=1
DOTNET_CLI_TELEMETRY_OPTOUT=1

# Browser Configuration for PDF Service
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_ARGS=--no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage

# Resource Limits (adjust for your development environment)
CALCPAD_SERVER_MEMORY=512m
PDF_SERVICE_MEMORY=256m

# Development Logging
ASPNETCORE_LOGGING__LOGLEVEL__DEFAULT=Information
ASPNETCORE_LOGGING__LOGLEVEL__MICROSOFT=Warning
ASPNETCORE_LOGGING__LOGLEVEL__SYSTEM=Information