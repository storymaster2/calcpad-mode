{
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File build-frontend.ps1 -Watch",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File build-frontend.ps1"
  },
  "bundle": {
    "targets": ["msi", "nsis"],
    "resources": {
      "binaries/*.dll": "./",
      "binaries/*.json": "./",
      "binaries/Calcpad.Server.exe": "./",
      "binaries/template.html": "./",
      "binaries/Fonts/*": "./Fonts/",
      "binaries/bg/*": "./bg/",
      "binaries/zh/*": "./zh/"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "perMachine"
      },
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-Command",
          "if ($env:CALCPAD_SIGN_THUMBPRINT) { signtool sign /sha1 $env:CALCPAD_SIGN_THUMBPRINT /fd sha256 /tr http://timestamp.digicert.com /td sha256 '{{ %1 }}' }"
        ]
      }
    }
  }
}
