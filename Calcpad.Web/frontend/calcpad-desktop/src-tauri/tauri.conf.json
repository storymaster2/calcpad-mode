{
  "productName": "CalcpadCE",
  "version": "0.3.0",
  "identifier": "com.calcpadce.desktop",
  "build": {
    "frontendDist": "../../calcpad-web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CalcpadCE",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https:; connect-src 'self' ipc: http://127.0.0.1:* https:; img-src 'self' data: blob: asset: http://asset.localhost https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; font-src 'self' data: https:",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "binaries/*.json": "./",
      "binaries/*.html": "./",
      "binaries/Fonts/**/*": "./Fonts/",
      "binaries/bg/**/*": "./bg/",
      "binaries/zh/**/*": "./zh/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "cpd"
        ],
        "name": "CalcpadCE Document",
        "description": "CalcpadCE calculation document",
        "mimeType": "application/x-calcpadce",
        "role": "Editor",
        "rank": "Default"
      }
    ],
    "category": "DeveloperTool",
    "shortDescription": "CalcpadCE desktop editor",
    "longDescription": "CalcpadCE is a Vue-based editor for CalcpadCE calculation files, backed by an embedded ASP.NET Core server.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
