# Maintainer: Isaiah Martin <isaiah@cei-engineering.com>
pkgname=calcpad-ce
pkgver=0.2.0
pkgrel=1
pkgdesc="CalcpadCE — Neutralino-based calculation editor with embedded .NET server"
arch=('x86_64')
url="https://calcpad-ce.org/"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3')
optdepends=('ungoogled-chromium-bin: PDF export support (preferred, prebuilt binary)'
            'ungoogled-chromium: PDF export support (source build, slow)'
            'chromium: PDF export support'
            'google-chrome: PDF export support'
            'microsoft-edge-stable: PDF export support')
makedepends=('npm' 'dotnet-sdk>=10.0' 'imagemagick')
install="${pkgname}.install"
options=('!strip' '!debug')

# Resolve the repo root from the PKGBUILD location.
_repo_root="$(cd "$startdir/../../../../.." && pwd)"
_desktop_dir="$_repo_root/Calcpad.Web/frontend/calcpad-desktop"

build() {
    cd "$_desktop_dir"
    npm install --no-audit --no-fund
    npx neu update
    bash ./build-desktop.sh
    npx neu build
}

package() {
    local opt_dir="$pkgdir/opt/$pkgname"
    install -dm755 "$opt_dir"

    # Neutralino runtime + bundled resources + binary
    install -Dm755 "$_desktop_dir/dist/calcpad-desktop/calcpad-desktop-linux_x64" \
        "$opt_dir/calcpad-desktop"
    install -Dm644 "$_desktop_dir/dist/calcpad-desktop/resources.neu" \
        "$opt_dir/resources.neu"

    # Embedded .NET server (preserves executable bits)
    cp -a "$_desktop_dir/dist/calcpad-desktop/extensions" "$opt_dir/"

    # Wrapper that sets env vars and exec's the binary from /opt
    install -Dm755 "$srcdir/../calcpad-ce.sh" "$pkgdir/usr/bin/$pkgname"

    # Desktop entry + icon
    install -Dm644 "$srcdir/../calcpad-ce.desktop" \
        "$pkgdir/usr/share/applications/$pkgname.desktop"
    install -Dm644 "$_desktop_dir/resources/icon.png" \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/$pkgname.png"

    install -Dm644 "$_repo_root/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
