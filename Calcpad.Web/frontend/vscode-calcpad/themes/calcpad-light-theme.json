{
  "name": "CalcPad Light",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#000000",
    "editorLineNumber.foreground": "#999999",
    "editorLineNumber.activeForeground": "#000000",
    "editor.selectionBackground": "#add6ff",
    "editor.inactiveSelectionBackground": "#e5ebf1",
    "editorWhitespace.foreground": "#b3b3b3cc",
    "editorIndentGuide.background": "#d3d3d3",
    "editorIndentGuide.activeBackground": "#939393",
    "editor.findMatchBackground": "#a8ac94",
    "editor.findMatchHighlightBackground": "#ea5c0055",
    "editor.findRangeHighlightBackground": "#b4b4b4cc",
    "editorBracketMatch.background": "#0064001a",
    "editorBracketMatch.border": "#b9b9b9"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "const:calcpad": "#000000",
    "operator:calcpad": "#DAA520",
    "bracket:calcpad": "#FF1493",
    "lineContinuation:calcpad": "#DAA520",
    "variable:calcpad": "#0000FF",
    "localVariable:calcpad": "#0066CC",
    "function:calcpad": { "foreground": "#000000", "bold": true },
    "macro:calcpad": "#8B008B",
    "macroParameter:calcpad": { "foreground": "#7B2FA0", "italic": true },
    "units:calcpad": "#008B8B",
    "setting:calcpad": "#0077AA",
    "keyword:calcpad": "#FF00FF",
    "controlBlockKeyword:calcpad": "#FF00FF",
    "endKeyword:calcpad": "#FF00FF",
    "command:calcpad": "#FF00FF",
    "include:calcpad": "#4B0082",
    "filePath:calcpad": "#4B0082",
    "dataExchangeKeyword:calcpad": "#FF00FF",
    "comment:calcpad": "#228B22",
    "htmlComment:calcpad": { "foreground": "#6B7D8D", "italic": true },
    "tag:calcpad": "#9932CC",
    "htmlContent:calcpad": "#2EA043",
    "javascript:calcpad": "#B8860B",
    "css:calcpad": "#0000CD",
    "svg:calcpad": "#006400",
    "input:calcpad": "#FF0000",
    "format:calcpad": "#A9A9A9",
    "stringVariable:calcpad": "#267F72",
    "stringFunction:calcpad": { "foreground": "#267F72", "bold": true },
    "stringTable:calcpad": "#6B8E23"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment.line.single-quote.calcpad",
        "comment.block.double-quote.calcpad"
      ],
      "settings": {
        "foreground": "#228B22",
        "fontStyle": ""
      }
    },
    {
      "name": "HTML Comments",
      "scope": "comment.block.html.calcpad",
      "settings": {
        "foreground": "#6B7D8D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword.control.calcpad",
        "keyword.other.calcpad"
      ],
      "settings": {
        "foreground": "#FF00FF",
        "fontStyle": ""
      }
    },
    {
      "name": "Commands",
      "scope": "support.function.command.calcpad",
      "settings": {
        "foreground": "#FF00FF",
        "fontStyle": ""
      }
    },
    {
      "name": "Functions",
      "scope": "support.function.builtin.calcpad",
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.numeric.calcpad",
        "constant.numeric.complex.calcpad"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables",
      "scope": "variable.other.calcpad",
      "settings": {
        "foreground": "#0000FF",
        "fontStyle": ""
      }
    },
    {
      "name": "Units",
      "scope": "support.type.units.calcpad",
      "settings": {
        "foreground": "#008B8B",
        "fontStyle": ""
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator.arithmetic.calcpad",
        "keyword.operator.comparison.calcpad",
        "keyword.operator.logical.calcpad",
        "keyword.operator.assignment.calcpad"
      ],
      "settings": {
        "foreground": "#DAA520",
        "fontStyle": ""
      }
    },
    {
      "name": "Separators",
      "scope": "punctuation.separator.calcpad",
      "settings": {
        "foreground": "#DAA520",
        "fontStyle": ""
      }
    },
    {
      "name": "Brackets",
      "scope": "punctuation.section.brackets.calcpad",
      "settings": {
        "foreground": "#FF1493",
        "fontStyle": ""
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "meta.tag.html.calcpad",
        "entity.name.tag.html.calcpad",
        "punctuation.definition.tag.begin.html.calcpad",
        "punctuation.definition.tag.end.html.calcpad"
      ],
      "settings": {
        "foreground": "#9932CC",
        "fontStyle": ""
      }
    },
    {
      "name": "HTML Attributes",
      "scope": "entity.other.attribute-name.html.calcpad",
      "settings": {
        "foreground": "#9932CC",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string.quoted.double.calcpad",
        "string.quoted.single.calcpad",
        "string.quoted.double.html.calcpad",
        "string.quoted.single.html.calcpad"
      ],
      "settings": {
        "foreground": "#228B22",
        "fontStyle": ""
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape.calcpad"
      ],
      "settings": {
        "foreground": "#B8860B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Macros",
      "scope": "variable.parameter.macro.calcpad",
      "settings": {
        "foreground": "#8B008B",
        "fontStyle": ""
      }
    },
    {
      "name": "Input",
      "scope": [
        "variable.language.input.calcpad",
        "punctuation.definition.input.calcpad"
      ],
      "settings": {
        "foreground": "#FF0000",
        "fontStyle": ""
      }
    },
    {
      "name": "Include",
      "scope": "keyword.control.include.calcpad",
      "settings": {
        "foreground": "#4B0082",
        "fontStyle": ""
      }
    },
    {
      "name": "Format",
      "scope": "meta.format.calcpad",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": ""
      }
    },
    {
      "name": "Error",
      "scope": "invalid.illegal.calcpad",
      "settings": {
        "foreground": "#DC143C",
        "fontStyle": ""
      }
    }
  ]
}