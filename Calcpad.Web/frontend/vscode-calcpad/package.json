    "package": "npm run build:vue && rollup -c --sourcemap",
    "package:full": "npm run build:vue && rollup -c --sourcemap && node -e \"require('fs').mkdirSync('dist/bin',{recursive:true})\" && echo 'Place CalcpadServer.dll in dist/bin/ before packaging'",
    "package:lite": "npm run build:vue && rollup -c --sourcemap",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "build:vue": "vite build",
    "watch:vue": "vite build --watch",
    "dev:vue": "vite build --watch --mode development",
    "type-check:vue": "vue-tsc --noEmit --project tsconfig.vue.json"
