' Units: SI, Imperial, custom, conversion, dimensionless, angle
' Dimensionless
permille = 25*‰
ppmVal = 100*ppm
ppbVal = 50*ppb
' Angle units
angleDeg = 45*deg
angleRad = 1.5708*rad
angleGrad = 50*grad
angleRev = 0.25*rev
' SI Mass
mass_g = 100*g
mass_kg = 5*kg
mass_t = 1*t
mass_mg = 500*mg
mass_μg = 100*μg
' SI Length
len_m = 5*m
len_km = 1*km
len_cm = 100*cm
len_mm = 50*mm
len_μm = 10*μm
len_nm = 500*nm
' SI Time
time_s = 30*s
time_ms = 500*ms
time_min = 5*min
time_h = 2*h
time_d = 1*d
' SI Frequency
freq_Hz = 60*Hz
freq_kHz = 1*kHz
freq_MHz = 100*MHz
freq_rpm = 3600*rpm
' SI Area/Volume
area_m2 = 100*m^2
area_ha = 1*ha
vol_L = 50*L
vol_mL = 500*mL
' SI Force
force_N = 100*N
force_kN = 50*kN
force_MN = 1*MN
' SI Pressure
press_Pa = 101325*Pa
press_kPa = 101.325*kPa
press_MPa = 200*MPa
press_bar = 1*bar
press_atm = 1*atm
press_mmHg = 760*mmHg
' SI Energy
energy_J = 500*J
energy_kJ = 10*kJ
energy_kWh = 1*kWh
energy_eV = 1*eV
energy_cal = 100*cal
' SI Power
power_W = 1000*W
power_kW = 5*kW
power_VA = 100*VA
power_VAR = 50*VAR
' Electrical
current_A = 5*A
current_mA = 100*mA
voltage_V = 220*V
voltage_kV = 11*kV
cap_F = 1*F
cap_μF = 100*μF
res_Ω = 1000*Ω
res_kΩ = 10*kΩ
cond_S = 1*S
flux_Wb = 1*Wb
fluxDens_T = 1*T
ind_H = 1*H
ind_mH = 100*mH
' SI Temperature
temp_C = 20*°C
temp_K = 293*K
' Imperial Mass
mass_oz = 16*oz
mass_lb = 10*lb
mass_slug = 1*slug
' Imperial Length
len_in = 12*in
len_ft = 10*ft
len_yd = 5*yd
len_mi = 1*mi
len_nmi = 1*nmi
' Imperial Temperature
temp_F = 72*°F
temp_R = 530*°R
' Imperial Force
force_lbf = 100*lbf
force_kip = 10*kip
force_ozf = 16*ozf
' Imperial Pressure
press_psi = 14.7*psi
press_psf = 2116*psf
press_ksi = 50*ksi
' Imperial Energy/Power
energy_BTU = 100*BTU
power_hp = 1*hp
' Imperial Volume
vol_floz = 8*fl_oz
vol_gal = 1*gal
vol_bbl = 1*bbl
' Moment
moment_Nm = 100*Nm
moment_kNm = 50*kNm
' Viscosity
visc_P = 1*P
visc_cP = 100*cP
visc_St = 1*St
visc_cSt = 100*cSt
' Speed
speed_kmh = 100*kmh
speed_mph = 60*mph
speed_knot = 10*knot
' Unit conversion with | separator
convert1 = 1*m|cm
convert2 = 1*ft|m
convert3 = 100*°C|°F
convert4 = 1*kip|kN
convert5 = 1*psi|kPa
convert6 = 3*ft + 12*in|cm
' Custom units
.EUR = 1
.USD = 0.92
.GBP = 1.17
price = 100*.EUR
priceUSD = price/.USD
