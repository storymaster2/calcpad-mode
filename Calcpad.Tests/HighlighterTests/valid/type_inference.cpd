' Type inference: type tracking, return types, element access
scalarVal = 42
scalarExpr = scalarVal*2 + 1
vecVal = [1; 2; 3; 4; 5]
vecFromFunc = vector(5)
vecFromRange = range(1; 10; 1)
vecFromSort = sort([5; 2; 8])
vecFromReverse = reverse([1; 2; 3])
vecFromUnit = unit([3; 4])
vecFromCross = cross([1; 0; 0]; [0; 1; 0])
vecFromRow = row([1; 2 | 3; 4]; 1)
vecFromCol = col([1; 2 | 3; 4]; 1)
vecFromDiag = diag2vec([1; 0 | 0; 1])
matVal = [1; 2 | 3; 4]
matFromFunc = matrix(3; 3)
matFromIdent = identity(3)
matFromDiag = diagonal(3; 1)
matFromTransp = transp(matVal)
matFromInverse = inverse([1; 0 | 0; 1])
matFromVec2diag = vec2diag([1; 2; 3])
matFromVec2row = vec2row([1; 2; 3])
matFromVec2col = vec2col([1; 2; 3])
matFromLU = lu([1; 2 | 3; 4])
matFromQR = qr([1; 2 | 3; 4])
matFromSVD = svd([1; 2 | 3; 4])
matFromAugment = augment(matVal; matVal)
matFromStack = stack(matVal; matVal)
hpVec = vector_hp(5)
hpMat = matrix_hp(3; 3)
hpIdent = identity_hp(3)
hpRange = range_hp(1; 100; 1)
hpConvert = hp(vecVal)
isHp = ishp(hpVec)
vecElem = vecVal.3
matElem = matVal.(1; 2)
vecVal.1 = 99
matVal.(2; 2) = 88
square(x) = x^2
funcResult = square(5)
.EUR = 1
unitPrice = 100*.EUR
#def greeting$ = 'Hello'
various = 1
various = [1; 2; 3]
' Vector type propagation through binary expressions
vecA = [10; 20; 30; 40]
vecB = [1; 2; 3; 4]
vecDiff = vecA - vecB
vecSum = vecA + vecB
vecScaled = vecA*2
elemFromDiff = vecDiff.3
elemFromSum = vecSum.1
elemFromScaled = vecScaled.4
' Scalar-returning functions wrapping vectors should NOT propagate vector type
vecLen = vector(len(vecA))
vecFromScalarFunc = vector(min(vecA) + max(vecB))
