' =========================================================
' Element Access Test
' =========================================================
' Dots are reserved exclusively for vector/matrix element access.
' They are NOT permitted inside variable or function names.
' For multi-part names, use comma separators (e.g., k,1).
'
' Rules:
' - `.` after an identifier is always element access
' - Comma is a valid identifier character (k,1 is one name)
' - `.(i)` and `.i` both work for element access on vectors
' - `M.(i; j)` accesses a matrix cell

' ---------------------------------------------------------
' SECTION 1: Comma-separated scalar names (replaces dotted scalars)
' ---------------------------------------------------------

k = 5
k,1 = 10
k,2 = 20
result,1 = k,1 + k,2
k,x = k,1 * 2
k,long,name = 100

total,scalars = k,1 + k,2 + k,x

' ---------------------------------------------------------
' SECTION 2: Vector definitions with element access
' ---------------------------------------------------------

vec = [1; 2; 3; 4; 5]
first = vec.1
second = vec.2
last = vec.(len(vec))

i = 3
elem = vec.i

' ---------------------------------------------------------
' SECTION 3: Matrix definitions with element access
' ---------------------------------------------------------

M = [1; 2; 3 | 4; 5; 6 | 7; 8; 9]
cell = M.(1; 2)
row1col3 = M.(1; 3)

' ---------------------------------------------------------
' SECTION 4: Vectors with comma-separated names
' v,1 is a single variable name; element access is v,1.k
' ---------------------------------------------------------

v,1 = [10; 20; 30]
v,1_first = v,1.1
v,1_second = v,1.2
v,1_last = v,1.(len(v,1))

data,set = [100; 200; 300; 400]
data,set_elem = data,set.2

' ---------------------------------------------------------
' SECTION 5: Element access on function parameters
' Functions cannot have dots in their names, so a dot after an
' identifier is unambiguously element access — both .i and .(i)
' work for parameters.
' ---------------------------------------------------------

getFirst(vect) = vect.(1)
getElement(vect; idx) = vect.(idx)
sumFirstTwo(vect) = vect.(1) + vect.(2)

addElements(a_vec; b_vec; idx) = a_vec.(idx) + b_vec.(idx)

r1 = getFirst(vec)
r2 = getElement(vec; 3)
r3 = sumFirstTwo(vec)
r4 = addElements(vec; vec; 2)

' ---------------------------------------------------------
' SECTION 6: $Inline / $Block command blocks with element access
' ---------------------------------------------------------

set(idx; v_param; val) = $Inline{helperV = v_param; helperV.(idx) = val; v_param = helperV}

appendV(v_param; val) = $Inline{ _
myLen = len(v_param); _
v_param = resize(v_param; myLen + 1); _
v_param.(myLen + 1) = val; v_param}

sumVector(v_param) = $Inline{ _
total = 0; _
$Repeat{total = total + v_param.(j) @ j = 1 : len(v_param)}; _
total}

matTrace(mat) = $Inline{ _
total = 0; _
$Repeat{total = total + mat.(k; k) @ k = 1 : n_rows(mat)}; _
total}

filterVecAnd(vf; v1; v2; v1_val; v2_val) = $Inline{ _
v1_ind = find(v1; v1_val; 1); v2_ind = find(v2; v2_val; 1); _
result = vector(0); _
$Repeat{if(len(find(v2_ind; v1_ind.i; 1)) ≡ 0; 0; take(v1_ind.i; vf)) @ i = 1 : len(v1_ind)}; _
result}

blockWithLocalVec(n) = $Inline{ _
localV = [1; 2; 3]; _
val = localV.n; _
val}

test_vec = [10; 20; 30; 40; 50]
set(2; test_vec; 99)
appendV(test_vec; 60)
vec_sum = sumVector(test_vec)

test_mat = [1; 2 | 3; 4]
mat_tr = matTrace(test_mat)

' ---------------------------------------------------------
' SECTION 7: #read variables (always vectors/matrices)
' ---------------------------------------------------------

' Uncomment to test with actual files:
'#read csv_data from testdata.csv
' After #read, csv_data.1 is element access

' ---------------------------------------------------------
' SECTION 8: Comma-separated names alongside vectors
' ---------------------------------------------------------

p,x = 5
p,y = 10

p,coords = [5; 10; 15]

p,coords_first = p,coords.1

combined = p,x + p,coords.1

' ---------------------------------------------------------
' SECTION 9: Commas in variable names (existing behavior)
' ---------------------------------------------------------

GC_r,NS = 5
GC_r,EW = 10
total_GC = GC_r,NS + GC_r,EW

calcWithCommas(factor) = $Inline{ _
local,var = factor * 2; _
result = local,var + 1; _
result}

commaResult = calcWithCommas(GC_r,NS)
