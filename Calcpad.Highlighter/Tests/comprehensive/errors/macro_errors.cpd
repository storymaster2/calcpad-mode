' CPD-22xx: Macro definition errors
' CPD-2201: Duplicate macro
#def dup$ = 1
#def dup$ = 2

' CPD-2202: Macro name without $
#def badMacro = 5

' CPD-2204: Invalid macro name
#def 123bad$ = 1

' CPD-2207: Nested macro def
#def outer$
	#def inner$ = 1
#end def

' CPD-2209: Macro inside control block
#if 1 > 0
	#def badPlace$ = 1
#end if

' CPD-2206: Unmatched #end def
#def unmatched$

' CPD-2212: Duplicate macro parameter
#def dupParam$(x$; x$) = x$
