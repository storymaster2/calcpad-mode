'<!--{"settings": {"complex": true}}-->'
' Output control: visibility, equation display, formatting, rounding
a = 10
b = 20
c = a + b
' Visibility control
#hide
hiddenVar = 999
#show
visibleVar = 42
#pre
preOnly = 1
#post
postOnly = 2
#show
' Equation display modes
#val
valOnly = a + b
#equ
equMode = a + b
#noc
nocMode = a + b
#equ
' Variable substitution
#nosub
nosubVar = a + b
#novar
novarVar = a + b
#varsub
varsubVar = a + b
' Rounding
#round 2
rounded2 = 3.14159265
#round 4
rounded4 = 3.14159265
#round default
' Format control
#format F2
formatted = 123.456789
#format N3
sigFigGrouped = 9055
#format default
' Trig unit switches
#deg
degResult = sin(90)
#rad
radResult = sin(1.5708)
#gra
graResult = sin(100)
#deg
' Complex output modes
z = 3 + 4i
#phasor
phasorZ = z
#complex
complexZ = z
' Markdown in comments
#md on
"**Bold** and *italic*"
#md off
' Constant protection
#const protected = 100