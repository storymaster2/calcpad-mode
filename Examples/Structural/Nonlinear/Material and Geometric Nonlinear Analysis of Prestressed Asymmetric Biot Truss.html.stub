   <var>v</var>
   <sub>2</sub>
   −
   <var>v</var>
   <sub>1</sub>
  </span>
  ,
  <span class="eq">
   <var>
    <span class="vec">⃗</span>
    z
   </var>
   =
   <span class="b0">[</span>
   <var>u</var>
   ;
   <var>v</var>
   <span class="b0">]</span>
  </span>
 </p>
