   </var>
   =
   <var>
    <span class="vec">⃗</span>
    Z
   </var>
   <sub>0</sub>
   −
   <var>
    <span class="vec">⃗</span>
    δZ
   </var>
  </span>
  ,
  <span class="eq">
   <var>ε</var>
   =
   <span class="dvc">
    <b>norm</b>
    <sub>e</sub>
    (
    <var>
     <span class="vec">⃗</span>
     δZ
    </var>
    )
    <span class="dvl">
    </span>
    <b>norm</b>
    <sub>e</sub>
    (
    <var>
     <span class="vec">⃗</span>
     Z
    </var>
    )
   </span>
   &lt;
   <var>ε</var>
   <sub>max</sub>
  </span>
 </p>
 <p>
  Convergence reached at iteration -
  <span class="eq">
