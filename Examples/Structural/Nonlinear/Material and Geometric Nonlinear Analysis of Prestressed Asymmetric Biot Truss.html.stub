   (
   <var>e</var>
   )  ·
   <span class="b0">[</span>
   <var>F</var>
   <sub>x</sub>
   (
   <var>e</var>
   ;
   <var>z</var>
   <sub>e</sub>
   (
   <var>e</var>
   )  ) ;
   <var>F</var>
   <sub>y</sub>
   (
   <var>e</var>
   ;
   <var>z</var>
   <sub>e</sub>
   (
   <var>e</var>
