 <p>Shear forces</p>
 <p>
  - in section
  <em>a</em>
  due to unit force at distance
  <em>x</em>
  from the beginning of the beam:
 </p>
 <p>
  <span class="eq">
   <var>V</var>
   <sub>1,a</sub>
   (
   <var>a</var>
   ;
   <var>x</var>
   )  =
   <span class="dvcs">
    <span class="c3">{</span>
    <span class="dvs">
     if
     <var>a</var>
     &lt;
     <var>x</var>
     :
     <span class="dvc">
      <var>x</var>
      <span class="dvl">
      </span>
      <var>L</var>
     </span>
     − 1
     <br/>
     else:
     <span class="dvc">
      <var>x</var>
      <span class="dvl">
      </span>
      <var>L</var>
     </span>
    </span>
   </span>
  </span>
 </p>
 <p>
  - in section
  <em>a</em>
  , due to unit force
  <em>X</em>
  <sub>i</sub>
  :
 </p>
 <p>
  <span class="eq">
   <var>V</var>
   <sub>1</sub>
   (
   <var>a</var>
   ;
   <var>i</var>
   )  =
   <var>V</var>
   <sub>1,a</sub>
   (
   <var>a</var>
   ;
   <var>
    <span class="vec">⃗</span>
    x
   </var>
   <sub>
    <var>i</var>
   </sub>
   )
  </span>
 </p>
