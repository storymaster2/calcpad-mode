    <sub>1</sub>
    =
    <u class="input-17">1</u>
   </span>
   m
  </p>
  <p>Bending</p>
  <p>
   <span class="eq">
    <var>M</var>
    (
    <var>x</var>
    )  = -
    <var>M</var>
    +
    <var>V</var>
    ·
    <var>x</var>
    −
    <span class="dvc">
     <var>q</var>
     ·  (
     <var>x</var>
     −
     <var>a</var>
     )
     <sup>2</sup>
     <span class="dvl">
     </span>
