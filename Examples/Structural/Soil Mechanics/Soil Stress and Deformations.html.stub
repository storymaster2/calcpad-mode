      <span class="dvl">
      </span>
      2
     </span>
    </small>
    <span class="nary">
     <em>∫</em>
    </span>
    <small>
     <span class="dvc">
      -
      <var>a</var>
      <span class="dvl">
      </span>
      2
     </span>
    </small>
   </span>
   <span class="dvc">
    <var>p</var>
    (
    <var>x</var>
    <sub>p</sub>
    ;
    <var>y</var>
    <sub>p</sub>
    )  ·
    <var>z</var>
    <sup>3</sup>
    <span class="dvl">
    </span>
    <var>R</var>
    (
    <var>x</var>
    −
    <var>x</var>
