   <var>σ</var>
   <sub>z</sub>
   (
   <var>x</var>
   ;
   <var>y</var>
   ;
   <var>z</var>
   )  =
   <span class="dvc">
    3
    <span class="dvl">
    </span>
    2 ·
    <var>π</var>
   </span>
   ·
   <span class="dvr">
    <small>
     <span class="dvc">
      <var>b</var>
      <span class="dvl">
      </span>
      2
     </span>
    </small>
    <span class="nary">
     <em>∫</em>
    </span>
    <small>
     <span class="dvc">
      -
      <var>b</var>
      <span class="dvl">
      </span>
