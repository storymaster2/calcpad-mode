    <td>
     Bottom parallel to
     <i>x</i>
    </td>
    <td>12.3</td>
    <td>2.52</td>
    <td>0.22%</td>
    <td>Ø8/19</td>
   </tr>
   <tr>
    <td>
     Bottom parallel to
     <i>y</i>
    </td>
    <td>8.68</td>
    <td>1.9</td>
    <td>0.18%</td>
    <td>Ø8/25</td>
   </tr>
