<div class="calcpad-output">
 <h3>
  Slab Panel with Restrained Longer Edge
  <hr/>
  <small>
   According to
   <strong>Eurocode</strong>
   : EN 1992-1-1
  </small>
 </h3>
 <div style="max-width:180mm;">
  <img alt="ssfs-span-cl.png" class="side" src="Images/structures/rc/spans/ssfs-span-cl.png" style="height:170pt;"/>
  <h4>Dimensions</h4>
  <p>
   Clear spans (
   <i>l</i>
   <sub>x</sub>
   &lt;
   <i>l</i>
   <sub>y</sub>
   )
  </p>
  <p>
   <span class="eq">
    <var>l</var>
    <sub>x_cl</sub>
    =
    <u class="input-6">4</u>
   </span>
   m,
   <span class="eq">
    <var>l</var>
    <sub>y_cl</sub>
    =
    <u class="input-6">6</u>
   </span>
   m
  </p>
  <p>
   Beam width along
   <i>x</i>
   -
   <span class="eq">
    <var>b</var>
    <sub>y</sub>
    =
    <u class="input-7">25</u>
   </span>
   cm
  </p>
  <p>
   Beam width along
   <i>y</i>
   -
   <span class="eq">
    <var>b</var>
    <sub>x</sub>
    =
    <u class="input-8">25</u>
   </span>
   cm
  </p>
  <p>
   Slab thickness -
   <span class="eq">
    <var>h</var>
    =
    <u class="input-9">14</u>
   </span>
   cm
  </p>
  <p>
   Concrete cover -
   <span class="eq">
    <var>c</var>
    =
    <u class="input-10">2</u>
   </span>
   cm
  </p>
  <p>Design span lengths</p>
  <p>
   <span class="eq">
    <var>l</var>
    <sub>x</sub>
    =
    <var>l</var>
    <sub>x_cl</sub>
    +
    <b>min</b>
    <span class="b1">(</span>
    <span class="dvc">
     <var>b</var>
     <sub>x</sub>
     <span class="dvl">
     </span>
     100
    </span>
    ;
    <span class="dvc">
     <var>h</var>
     <span class="dvl">
     </span>
     100
    </span>
    <span class="b1">)</span>
    = 4 +
    <b>min</b>
    <span class="b1">(</span>
    <span class="dvc">
     25
     <span class="dvl">
     </span>
     100
    </span>
    ;
    <span class="dvc">
     14
     <span class="dvl">
     </span>
     100
    </span>
    <span class="b1">)</span>
    = 4.14
   </span>
   m
  </p>
  <p>
   <span class="eq">
    <var>l</var>
    <sub>y</sub>
    =
    <var>l</var>
    <sub>y_cl</sub>
    +
    <b>min</b>
    <span class="b1">(</span>
    <span class="dvc">
     <var>b</var>
     <sub>y</sub>
     <span class="dvl">
     </span>
     100
    </span>
    ;
    <span class="dvc">
     <var>h</var>
     <span class="dvl">
     </span>
     100
    </span>
    <span class="b1">)</span>
    = 6 +
    <b>min</b>
    <span class="b1">(</span>
    <span class="dvc">
     25
     <span class="dvl">
     </span>
     100
    </span>
    ;
    <span class="dvc">
     14
     <span class="dvl">
     </span>
     100
    </span>
    <span class="b1">)</span>
    = 6.14
   </span>
   m
  </p>
  <p>
   Span ratio -
   <span class="eq">
    <var>k</var>
    =
    <span class="dvc">
     <var>l</var>
     <sub>y</sub>
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>x</sub>
    </span>
    =
    <span class="dvc">
