    <u class="input-10">2</u>
   </span>
   cm
  </p>
  <p>Design span lengths</p>
  <p>
   <span class="eq">
    <var>l</var>
    <sub>x</sub>
    =
    <var>l</var>
    <sub>x_cl</sub>
    +
    <b>min</b>
    <span class="b1">(</span>
