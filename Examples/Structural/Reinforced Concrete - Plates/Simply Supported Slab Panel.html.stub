   <span class="eq">
    <var>l</var>
    <sub>y_cl</sub>
    =
    <u class="input-6">6</u>
   </span>
   m
  </p>
  <p>
   Beam width along
   <i>x</i>
   -
   <span class="eq">
    <var>b</var>
    <sub>y</sub>
    =
    <u class="input-7">25</u>
   </span>
   cm
  </p>
  <p>
   Beam width along
   <i>y</i>
