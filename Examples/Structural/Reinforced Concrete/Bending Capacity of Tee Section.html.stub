      <sub>1</sub>
      ·
      <var>x</var>
      ·
      <var>b</var>
      <sub>f</sub>
      −
      <var>k</var>
      <sub>1</sub>
      (
      <var>ε</var>
      <sub>cf</sub>
      (
      <var>x</var>
      )  )  ·  (
      <var>x</var>
      −
      <var>h</var>
      <sub>f</sub>
      )  ·  (
      <var>b</var>
      <sub>f</sub>
      −
      <var>b</var>
      <sub>w</sub>
      )
     </span>
     =
     <span class="dvc">
      0.473 · 147.5
      <sup>2</sup>
      · 1200 −
      <var>k</var>
      <sub>2</sub>
      (
      <var>ε</var>
      <sub>cf</sub>
      ( 147.5 )  )  ·  ( 147.5 − 120 )
      <sup>2</sup>
      ·  ( 1200 − 300 )
      <span class="dvl">
      </span>
      0.81 · 147.5 · 1200 −
      <var>k</var>
      <sub>1</sub>
      (
      <var>ε</var>
      <sub>cf</sub>
      ( 147.5 )  )  ·  ( 147.5 − 120 )  ·  ( 1200 − 300 )
     </span>
     = 86.93
    </span>
    cm
   </p>
   <p>- from the bottom edge of the section</p>
   <p>
    <span class="eq">
     <var>z</var>
     <sub>c</sub>
     =
