    <sub>2</sub>
    <span class="b1">)</span>
    <span class="b1">)</span>
    · 10
    <sup>-3</sup>
    =
    <span class="b1">(</span>
    <var>N</var>
    <sub>c</sub>
    ( 420.59 )  · 175.05 +
    <var>N</var>
    <sub>s1</sub>
    ( 420.59 )  ·
    <span class="b1">(</span>
    <span class="dvc">
     700
     <span class="dvl">
     </span>
     2
    </span>
    − 50
    <span class="b1">)</span>
    −
    <var>N</var>
    <sub>s2</sub>
    ( 420.59 )  ·
    <span class="b1">(</span>
    <span class="dvc">
