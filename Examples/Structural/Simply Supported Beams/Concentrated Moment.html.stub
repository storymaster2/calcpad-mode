     <span class="dvl">
     </span>
     <var>l</var>
    </span>
    ·  (
    <var>l</var>
    −
    <var>a</var>
    )  =
    <span class="dvc">
     10
     <span class="dvl">
     </span>
     5
    </span>
    ·  ( 5 − 2 )  = 6
   </span>
   kN·m
  </p>
  <p>Shear</p>
  <p>
   <span class="eq">
    <var>V</var>
    =
    <span class="dvc">
     <var>M</var>
     <span class="dvl">
     </span>
     <var>l</var>
    </span>
    =
    <span class="dvc">
     10
     <span class="dvl">
     </span>
     5
    </span>
    = 2
   </span>
   kN
  </p>
  <p>
   <b>Diagrams</b>
  </p>
  <p>
