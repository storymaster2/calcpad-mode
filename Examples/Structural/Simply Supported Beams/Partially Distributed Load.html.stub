<div class="calcpad-output">
 <!-- Uniform load $q$ acting on a stretch of length $b$ between offsets $a$ and $c = l - a - b$, with a guard against an invalid load length when $a + b > l$. -->
 <div style="max-width:180mm;">
  <img alt="simply-supported-beam-distributed-load-partial.png" class="side" src="Images/mechanics/beams/simply-supported-beam-distributed-load-partial.png" style="width:190pt;"/>
  <p>
   <b>Input data</b>
  </p>
  <p>
   Beam length -
   <span class="eq">
    <var>l</var>
    =
    <u class="input-5">5</u>
   </span>
   m
  </p>
  <p>
   Load -
   <span class="eq">
    <var>q</var>
    =
    <u class="input-6">10</u>
   </span>
   kN/m
  </p>
  <p>
   Distances -
   <span class="eq">
    <var>a</var>
    =
    <u class="input-7">1</u>
   </span>
   m,
   <span class="eq">
    <var>b</var>
    =
    <u class="input-7">2</u>
   </span>
   m
  </p>
  <p>
   <span class="eq">
    <var>c</var>
    =
    <var>l</var>
    −  (
    <var>a</var>
    +
    <var>b</var>
    )  = 5 −  ( 1 + 2 )  = 2
   </span>
   m
  </p>
  <p>
   <b>Internal forces</b>
  </p>
  <p>
   Distance -
   <span class="eq">
    <var>x</var>
    <sub>max</sub>
    =
    <var>a</var>
    +
    <span class="dvc up">
     <var>b</var>
     ·
     <span class="b1">(</span>
     <span class="dvc">
      <var>b</var>
      <span class="dvl">
      </span>
      2
     </span>
     +
     <var>c</var>
     <span class="b1">)</span>
     <span class="dvl">
     </span>
     <var>l</var>
    </span>
    = 1 +
    <span class="dvc up">
     2 ·
     <span class="b1">(</span>
