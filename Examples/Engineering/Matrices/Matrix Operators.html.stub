 </p>
 <p>
  <span class="eq">
   <b>
    <var>A</var>
   </b>
   mod 2 =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">0</span>
     <span class="td">1</span>
     <span class="td">0</span>
