 </p>
 <p>
 </p>
 <h4>Scalar-matrix</h4>
 <p>
  <span class="eq">
   <var>a</var>
   = 2
  </span>
  ,
  <span class="eq">
   <b>
    <var>B</var>
   </b>
   =
   <span class="b0">[</span>
   11; 10; 9
   <span class="b0">|</span>
   8; 7; 6
   <span class="b0">]</span>
