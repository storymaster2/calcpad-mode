     <span class="td">0</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">3</span>
     <span class="td">4</span>
     <span class="td">0</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">5</span>
     <span class="td">6</span>
     <span class="td">7</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">8</span>
     <span class="td">9</span>
     <span class="td">10</span>
     <span class="td">
     </span>
    </span>
   </span>
  </span>
  - creates a 4x3 rectangular matrix
 </p>
 <p>
  <span class="eq">
   <b>diag2vec</b>
   (
   <b>
    <var>A</var>
   </b>
   )  =
   <b class="b0">[</b>
   1 4 7
   <b class="b0">]</b>
  </span>
  - extracts the elements along the main diagonal into a new vector
 </p>
 <p>
 </p>
 <p>
  <b>Submatrix</b>
  (
  <em>matrix</em>
  ;
  <em>start row</em>
  ;
  <em>end row</em>
  ;
  <em>start column</em>
  ;
  <em>end column</em>
  )
 </p>
 <hr/>
 <p>
  <span class="eq">
   <b>
    <var>A</var>
   </b>
   =
   <span class="b0">[</span>
   1; 2; 3; 4
   <span class="b0">|</span>
   5; 6; 7; 8
   <span class="b0">|</span>
   9; 10; 11; 12
   <span class="b0">|</span>
   13; 14; 15; 16
   <span class="b0">]</span>
   =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">1</span>
     <span class="td">2</span>
     <span class="td">3</span>
     <span class="td">4</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">5</span>
     <span class="td">6</span>
     <span class="td">7</span>
     <span class="td">8</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">9</span>
     <span class="td">10</span>
     <span class="td">11</span>
     <span class="td">12</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">13</span>
     <span class="td">14</span>
     <span class="td">15</span>
     <span class="td">16</span>
     <span class="td">
     </span>
    </span>
   </span>
  </span>
  - creates a 4x4 general matrix
 </p>
 <p>
  <span class="eq">
   <b>submatrix</b>
   (
   <b>
    <var>A</var>
   </b>
   ; 2; 3; 2; 4 )  =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">6</span>
     <span class="td">7</span>
     <span class="td">8</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">10</span>
     <span class="td">11</span>
     <span class="td">12</span>
     <span class="td">
     </span>
    </span>
   </span>
  </span>
  - extracts the values between rows 2 and 3 and between columns 2 and 4 into a new matrix
 </p>
