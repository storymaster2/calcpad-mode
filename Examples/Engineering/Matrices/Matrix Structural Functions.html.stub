<div class="calcpad-output">
 <!-- Structural plumbing for matrices: $n_{rows}$, $n_{cols}$, resize, join, reshape, submatrix and the slicing helpers that feed the rest of the toolkit. -->
 <style>em {font-family:"Times New Roman";}</style>
 <p>
  <b>N_Rows</b>
  (
  <em>matrix</em>
  )
 </p>
 <hr/>
 <p>
  <span class="eq">
   <b>
    <var>A</var>
   </b>
   =
   <span class="b0">[</span>
   1; 2
   <span class="b0">|</span>
   3; 4
   <span class="b0">|</span>
   5; 6
   <span class="b0">]</span>
   =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">1</span>
     <span class="td">2</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">3</span>
     <span class="td">4</span>
     <span class="td">
     </span>
    </span>
    <span class="tr">
     <span class="td">
     </span>
     <span class="td">5</span>
     <span class="td">6</span>
     <span class="td">
     </span>
    </span>
   </span>
  </span>
 </p>
 <p>
  <span class="eq">
   <b>n</b>
   <sub>rows</sub>
   (
   <b>
    <var>A</var>
   </b>
   )  = 3
  </span>
  - the number of rows in A
 </p>
