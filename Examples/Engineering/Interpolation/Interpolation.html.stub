   ; 0.75; 0.75; 1; 1.25; 1.5; 1.7; 1.85; 2; 2.25; 2.45; 2.65; 2.75; 2.75 )
  </span>
 </p>
 <p>Load for terrain type B</p>
 <p>
  <span class="eq">
   <var>k</var>
   <sub>zB</sub>
   (
   <var>x</var>
   )  =
   <b>line</b>
   (
   <var>x</var>
   ; 0.5; 0.5; 0.65; 0.85; 1.1; 1.3; 1.45; 1.6; 1.9; 2.1; 2.3; 2.5; 2.75 )
  </span>
 </p>
 <p>Interpolation factor</p>
 <p>
  <span class="eq">
   <var>k</var>
   (
   <var>z</var>
   )  =
   <span class="cond">$Root</span>
   {
   <var>Z</var>
   (
   <var>x</var>
   )  =
   <var>z</var>
   ;
   <var>x</var>
   ∈ [1; 12]}
  </span>
 </p>
