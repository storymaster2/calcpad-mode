      </span>
      <var>l</var>
     </span>
     ·
     <b>sin</b>
     ( -
     <var>θ</var>
     <sub>i</sub>
     )  −
     <span class="dvc">
      <var>b</var>
      <span class="dvl">
      </span>
      <var>m</var>
     </span>
     ·
     <var>k</var>
