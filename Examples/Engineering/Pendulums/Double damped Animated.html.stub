   <sub>2</sub>
   ·
   <var>θ″</var>
   <sub>1</sub>
   ·
   <b>cos</b>
   (
   <var>Δ</var>
   <sub>θ</sub>
   )  −
   <var>m</var>
   <sub>2</sub>
   ·
   <var>l</var>
   <sub>1</sub>
   ·
