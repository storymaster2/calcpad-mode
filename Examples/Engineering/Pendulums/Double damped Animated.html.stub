   ·
   <var>g</var>
   ·
   <b>sin</b>
   (
   <var>θ</var>
   <sub>1</sub>
   )  +
   <var>b</var>
   <sub>1</sub>
   ·
   <var>θ′</var>
   <sub>1</sub>
   = 0
  </span>
 </p>
 <p>
  <span class="eq">
   <var>m</var>
   <sub>2</sub>
   ·
   <var>l</var>
   <sub>2</sub>
   <sup>2</sup>
   ·
   <var>θ″</var>
   <sub>2</sub>
   +
   <var>m</var>
   <sub>2</sub>
   ·
