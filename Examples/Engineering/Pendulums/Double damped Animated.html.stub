   <sub>2</sub>
   ·
   <var>l</var>
   <sub>1</sub>
   ·
   <var>l</var>
   <sub>2</sub>
   ·
   <var>θ′</var>
   <sub>2</sub>
   <sup>2</sup>
   ·
   <b>sin</b>
   (
   <var>Δ</var>
   <sub>θ</sub>
   )  +
