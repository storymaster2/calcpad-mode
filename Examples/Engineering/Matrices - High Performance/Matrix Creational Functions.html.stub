  (
  <em>m</em>
  ;
  <em>n</em>
  )
 </p>
 <hr/>
 <p>
  <span class="eq">
   <b>matrix</b>
   <sub>hp</sub>
   ( 3; 4 )  =
   <span class="matrix">
    <span class="tr">
     <span class="td">
     </span>
