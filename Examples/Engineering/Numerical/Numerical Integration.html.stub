 <h4>CalcpadCE</h4>
 <hr/>
 <p>
  Adaptive Tanh-Sinh -
  <span class="eq">
   <var>I</var>
   <sub>ATH</sub>
   =
   <span class="dvr">
    <small>1</small>
    <span class="nary">
     <em>∫</em>
    </span>
    <small>-1</small>
   </span>
   <var>f</var>
   (
   <var>x</var>
   )  d
   <var>x</var>
   = 1.57
  </span>
 </p>
 <p>
