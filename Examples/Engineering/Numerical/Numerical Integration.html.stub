  </span>
 </p>
 <p>
  <span class="eq">
   <var>x</var>
   <sub>3</sub>
   = 0
  </span>
  ,
  <span class="eq">
   <var>y</var>
   <sub>3</sub>
   =
   <var>f</var>
   (
   <var>x</var>
   <sub>3</sub>
   )  =
