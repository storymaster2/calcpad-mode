 <h4>Gauss-Legendre rule</h4>
 <hr/>
 <p>
  <strong>Abscissas, Ordinates and weights</strong>
 </p>
 <p>
  <span class="eq">
   <var>x</var>
   <sub>1</sub>
   = -
   <span class="dvc">
    1
    <span class="dvl">
    </span>
    3
   </span>
   ·
   <span class="o1">
    <span class="r1">
    </span>
    5 + 2 ·
    <span class="o1">
     <span class="r1">
     </span>
     <span class="dvc">
      10
      <span class="dvl">
      </span>
      7
     </span>
    </span>
   </span>
   = -0.906
  </span>
  ,
  <span class="eq">
   <var>y</var>
   <sub>1</sub>
   =
   <var>f</var>
   (
   <var>x</var>
   <sub>1</sub>
   )  =
   <var>f</var>
   ( -0.906 )  = 0.423
  </span>
  ,
  <span class="eq">
   <var>w</var>
   <sub>1</sub>
   =
   <span class="dvc">
    322 − 13 ·
    <span class="o0">
     <span class="r">√</span>
     70
    </span>
    <span class="dvl">
    </span>
    900
   </span>
   = 0.237
  </span>
 </p>
 <p>
  <span class="eq">
   <var>x</var>
   <sub>2</sub>
   = -
   <span class="dvc">
    1
    <span class="dvl">
    </span>
    3
   </span>
   ·
   <span class="o1">
    <span class="r1">
    </span>
    5 − 2 ·
    <span class="o1">
     <span class="r1">
     </span>
     <span class="dvc">
      10
      <span class="dvl">
      </span>
      7
     </span>
    </span>
   </span>
   = -0.538
  </span>
  ,
  <span class="eq">
   <var>y</var>
   <sub>2</sub>
   =
   <var>f</var>
   (
   <var>x</var>
   <sub>2</sub>
   )  =
   <var>f</var>
   ( -0.538 )  = 0.843
  </span>
  ,
  <span class="eq">
   <var>w</var>
   <sub>2</sub>
   =
   <span class="dvc">
    322 + 13 ·
    <span class="o0">
     <span class="r">√</span>
     70
    </span>
    <span class="dvl">
    </span>
    900
   </span>
   = 0.479
  </span>
 </p>
 <p>
  <span class="eq">
   <var>x</var>
   <sub>3</sub>
   = 0
  </span>
  ,
  <span class="eq">
   <var>y</var>
   <sub>3</sub>
   =
   <var>f</var>
   (
   <var>x</var>
   <sub>3</sub>
   )  =
   <var>f</var>
   ( 0 )  = 1
  </span>
  ,
  <span class="eq">
   <var>w</var>
   <sub>3</sub>
   =
   <span class="dvc">
    128
    <span class="dvl">
    </span>
    225
   </span>
   = 0.569
  </span>
 </p>
 <p>
  <strong>Integral</strong>
 </p>
 <p>
  Value -
  <span class="eq">
   <var>I</var>
   <sub>G</sub>
   = 2 ·
   <var>w</var>
   <sub>1</sub>
   ·
   <var>y</var>
   <sub>1</sub>
   + 2 ·
   <var>w</var>
   <sub>2</sub>
   ·
   <var>y</var>
   <sub>2</sub>
   +
   <var>w</var>
   <sub>3</sub>
   ·
   <var>y</var>
   <sub>3</sub>
   = 2 · 0.237 · 0.423 + 2 · 0.479 · 0.843 + 0.569 · 1 = 1.58
  </span>
 </p>
 <p>
  Error -
