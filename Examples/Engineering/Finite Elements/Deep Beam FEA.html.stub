  <circle class="joint" cx="400" cy="0" r="2">
  </circle>
  <text text-anchor="start" x="402" y="-2">231</text>
 </svg>
 <h3>Finite element formation</h3>
 <p>
  <b>Shape functions</b>
 </p>
 <p>They are defined in relative coordinates to the center of the element:</p>
 <img alt="plane-elemen.png" src="./plane-element.png" style="float:right; width:150pt;">
  <p>
   <span class="eq">
    <var>ξ</var>
    =
    <span class="dvc">
     2 ·  (
     <var>x</var>
     −
     <var>
      <span class="vec">⃗</span>
      x
     </var>
     <sub>c</sub>
     )
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>1</sub>
    </span>
   </span>
   ∈ (-1; 1),
   <span class="eq">
    <var>η</var>
    =
    <span class="dvc">
     2 ·  (
     <var>y</var>
     −
     <var>
      <span class="vec">⃗</span>
      y
     </var>
     <sub>c</sub>
     )
     <span class="dvl">
     </span>
     <var>h</var>
     <sub>1</sub>
    </span>
   </span>
   ∈ (-1; 1)
  </p>
  <p>
   Base functions -
   <span class="eq">
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    )  =
    <span class="dvc">
     1 −
     <var>ξ</var>
     <span class="dvl">
     </span>
     2
    </span>
   </span>
   ,
   <span class="eq">
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    )  =
    <span class="dvc">
     1 +
     <var>ξ</var>
     <span class="dvl">
     </span>
     2
    </span>
   </span>
  </p>
  <p>
   First derivatives -
   <span class="eq">
    <var>Φ′</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    )  =
    <span class="dvc">
     -1
     <span class="dvl">
     </span>
     2
    </span>
   </span>
   ,
   <span class="eq">
    <var>Φ′</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    )  =
    <span class="dvc">
     1
     <span class="dvl">
     </span>
     2
    </span>
   </span>
  </p>
  <p>Shape functions for joints at elements` corners</p>
  <p>
   <span class="eq">
    <var>N</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    ;
    <var>η</var>
    )  =
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    )  ·
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>η</var>
    )
   </span>
   ,
   <span class="eq">
    <var>N</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    ;
    <var>η</var>
    )  =
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    )  ·
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>η</var>
    )
   </span>
  </p>
  <p>
   <span class="eq">
    <var>N</var>
    <sub>3</sub>
    (
    <var>ξ</var>
    ;
    <var>η</var>
    )  =
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    )  ·
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>η</var>
    )
   </span>
   ,
   <span class="eq">
    <var>N</var>
    <sub>4</sub>
    (
    <var>ξ</var>
    ;
    <var>η</var>
    )  =
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    )  ·
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>η</var>
    )
   </span>
  </p>
  <p>
   <b>Constitutive matrix</b>
   (stress-strain relationship)
  </p>
  <p>
   <span class="eq">
    <b>
     <var>D</var>
    </b>
    =
    <span class="dvc">
     <var>E</var>
     ·
     <var>t</var>
     <span class="dvl">
     </span>
     1 −
     <var>ν</var>
     <sup>2</sup>
    </span>
    ·
    <span class="b1">[</span>
    1;
    <var>ν</var>
    ; 0
    <span class="b0">|</span>
    <var>ν</var>
    ; 1; 0
    <span class="b0">|</span>
    0; 0;
    <span class="dvc">
     1 −
     <var>ν</var>
     <span class="dvl">
     </span>
     2
    </span>
    <span class="b1">]</span>
    =
    <span class="dvc">
     20000 · 0.1
     <span class="dvl">
     </span>
     1 − 0.2
     <sup>2</sup>
    </span>
    ·
    <span class="b1">[</span>
    1; 0.2; 0
    <span class="b0">|</span>
    0.2; 1; 0
    <span class="b0">|</span>
    0; 0;
    <span class="dvc">
     1 − 0.2
     <span class="dvl">
     </span>
     2
    </span>
    <span class="b1">]</span>
    =
    <span class="matrix">
     <span class="tr">
      <span class="td">
      </span>
      <span class="td">2083.33</span>
      <span class="td">416.67</span>
      <span class="td">0</span>
      <span class="td">
      </span>
     </span>
     <span class="tr">
      <span class="td">
      </span>
      <span class="td">416.67</span>
      <span class="td">2083.33</span>
      <span class="td">0</span>
      <span class="td">
      </span>
     </span>
     <span class="tr">
      <span class="td">
      </span>
      <span class="td">0</span>
      <span class="td">0</span>
      <span class="td">833.33</span>
      <span class="td">
      </span>
     </span>
    </span>
   </span>
  </p>
  <p>
   <b>Strain-displacement matrix</b>
  </p>
  <p>
   <span class="eq">
    <var>B</var>
    <sub>1</sub>
    (
    <var>j</var>
    ;
    <var>η</var>
    )  =
    <span class="dvc">
     1
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>1</sub>
    </span>
    ·
    <b>take</b>
    (
    <var>j</var>
    ; -
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>η</var>
    ) ; 0; -
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>η</var>
    ) ; 0;
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>η</var>
    ) ; 0;
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>η</var>
    ) ; 0 )
   </span>
  </p>
  <p>
   <span class="eq">
    <var>B</var>
    <sub>2</sub>
    (
    <var>j</var>
    ;
    <var>ξ</var>
    )  =
    <span class="dvc">
     1
     <span class="dvl">
     </span>
     <var>h</var>
     <sub>1</sub>
    </span>
    ·
    <b>take</b>
    (
    <var>j</var>
    ; 0; -
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    ) ; 0;
    <var>Φ</var>
    <sub>1</sub>
    (
    <var>ξ</var>
    ) ; 0; -
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    ) ; 0;
    <var>Φ</var>
    <sub>2</sub>
    (
    <var>ξ</var>
    )  )
   </span>
  </p>
  <p>
   <span class="eq">
    <var>B</var>
    <sub>3</sub>
    (
    <var>j</var>
    ;
    <var>ξ</var>
    ;
    <var>η</var>
    )  =
    <b>take</b>
    <span class="b1">(</span>
    <var>j</var>
    ;
    <span class="dvc">
     -
     <var>Φ</var>
     <sub>1</sub>
     (
     <var>ξ</var>
     )
     <span class="dvl">
     </span>
     <var>h</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     -
     <var>Φ</var>
     <sub>1</sub>
     (
     <var>η</var>
     )
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     <var>Φ</var>
     <sub>1</sub>
     (
     <var>ξ</var>
     )
     <span class="dvl">
     </span>
     <var>h</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     -
     <var>Φ</var>
     <sub>2</sub>
     (
     <var>η</var>
     )
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     -
     <var>Φ</var>
     <sub>2</sub>
     (
     <var>ξ</var>
     )
     <span class="dvl">
     </span>
     <var>h</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     <var>Φ</var>
     <sub>1</sub>
     (
     <var>η</var>
     )
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     <var>Φ</var>
     <sub>2</sub>
     (
     <var>ξ</var>
     )
     <span class="dvl">
     </span>
     <var>h</var>
     <sub>1</sub>
    </span>
    ;
    <span class="dvc">
     <var>Φ</var>
     <sub>2</sub>
     (
     <var>η</var>
     )
     <span class="dvl">
     </span>
     <var>l</var>
     <sub>1</sub>
    </span>
    <span class="b1">)</span>
   </span>
  </p>
  <p>
   <span class="eq">
    <var>B</var>
    (
    <var>j</var>
    ;
    <var>ξ</var>
    ;
    <var>η</var>
    )  =
    <span class="b0">[</span>
    <var>B</var>
    <sub>1</sub>
    (
    <var>j</var>
    ;
    <var>η</var>
    ) ;
    <var>B</var>
    <sub>2</sub>
    (
    <var>j</var>
    ;
    <var>ξ</var>
    ) ;
    <var>B</var>
    <sub>3</sub>
    (
    <var>j</var>
    ;
    <var>ξ</var>
    ;
    <var>η</var>
    )
    <span class="b0">]</span>
   </span>
  </p>
  <p>The elements of the stiffness matrix will be calculated by using direct integration</p>
  <p>
   <span class="eq">
    <var>K</var>
    <sub>e,ij</sub>
    =
    <span class="dvc">
     <var>l</var>
     <sub>1</sub>
     ·
     <var>h</var>
     <sub>1</sub>
     <span class="dvl">
     </span>
     4
    </span>
    ·
    <span class="dvr">
     <small>1</small>
     <span class="nary">
      <em>∫</em>
     </span>
     <small>-1</small>
    </span>
    <span class="dvr">
     <small>1</small>
     <span class="nary">
