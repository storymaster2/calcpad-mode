    <span class="o0">
     <span class="r">√</span>
     (
     <var>N</var>
     <sub>x</sub>
     (
     <var>x</var>
     ;
     <var>y</var>
     )  −
     <var>N</var>
     <sub>y</sub>
     (
     <var>x</var>
     ;
     <var>y</var>
     )  )
     <sup>2</sup>
     + 4 ·
     <var>N</var>
     <sub>xy</sub>
     (
     <var>x</var>
     ;
     <var>y</var>
     )
     <sup>2</sup>
    </span>
   </span>
  </p>
