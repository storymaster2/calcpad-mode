    </span>
    <span class="dvc">
     0.0713
     <span class="dvl">
     </span>
     0.785
    </span>
   </span>
   = 0.301
  </span>
  m
 </p>
 <p>
  <span class="eq">
   <var>r</var>
   <sub>x</sub>
   =
   <span class="o1">
    <span class="r1">
    </span>
    <span class="dvc">
     <var>I</var>
     <sub>x</sub>
     <span class="dvl">
