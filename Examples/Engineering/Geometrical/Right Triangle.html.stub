    <var>a</var>
    <sup>2</sup>
    +
    <var>b</var>
    <sup>2</sup>
   </span>
   = 2 + 1 +
   <span class="o0">
    <span class="r">√</span>
    2
    <sup>2</sup>
    + 1
    <sup>2</sup>
   </span>
   = 5.24
  </span>
  m
  <sup>2</sup>
 </p>
