<div class="calcpad-output">
 <!-- Section properties of a square rhombus (rotated square): area, $I_x = I_y$, section moduli and radii of gyration. -->
 <h3>Geometrical Properties of Square Rhombus</h3>
 <div style="max-width:120mm">
  <img alt="rombus-square.png" class="side" src="Images/mechanics/sections/rhombus.png" style="height:135pt;"/>
 </div>
 <p>Side length</p>
 <p>
  <span class="eq">
   <var>a</var>
   =
   <u class="input-5">1</u>
  </span>
  m
 </p>
 <p>Diagonal length</p>
 <p>
  <span class="eq">
   <var>d</var>
