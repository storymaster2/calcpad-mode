    <span class="r">√</span>
    2 · 1
    <sup>2</sup>
   </span>
   = 1.41
  </span>
  m
 </p>
 <p>Area</p>
 <p>
  <span class="eq">
   <var>A</var>
   =
   <var>a</var>
   <sup>2</sup>
   = 1
   <sup>2</sup>
   = 1
  </span>
  m
  <sup>2</sup>
 </p>
 <p>Centroid</p>
 <p>
  <i>z</i>
  <sub>c</sub>
  =
  <span class="eq">
