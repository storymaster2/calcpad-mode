   <sub>f</sub>
   ·  (
   <var>b</var>
   <sub>f</sub>
   +
   <var>t</var>
   <sub>w</sub>
   )  =
   <span class="dvc">
    20 · 1
    <span class="dvl">
    </span>
    2
   </span>
   + 18 ·  ( 10 + 1 )  = 208
  </span>
  m
  <sup>3</sup>
 </p>
 <p>
  <span class="eq">
   <var>y</var>
   <sub>c</sub>
