   <span class="o1">
    <span class="r1">
    </span>
    <span class="dvc">
     0.667
     <span class="dvl">
     </span>
     2
    </span>
   </span>
   = 0.577
  </span>
  m
 </p>
 <p>
  <span class="eq">
   <var>r</var>
   <sub>z</sub>
